# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get your token at https://account.mapbox.com/
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# ─── TonConnect ───────────────────────────────────────────────────────────────
# Leave UNSET for local dev (app auto-detects localhost origin).
# Set to your deployed production URL for staging/prod (no trailing slash).
VITE_APP_URL=https://your-ton-eats-app.vercel.app

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# The @username of your Telegram bot (without the @).
# Used to build viral referral deep links: t.me/<BOT_NAME>/app?startapp=...
VITE_BOT_NAME=YourTONEatsBot

# ─── TON-Eats Smart Contract (after deployment) ───────────────────────────────
VITE_ESCROW_CONTRACT_MAINNET=EQB_your_mainnet_contract_address
VITE_ESCROW_CONTRACT_TESTNET=EQB_your_testnet_contract_address

# ─── Protocol Treasury ────────────────────────────────────────────────────────
# Wallet that collects the 0.1 TON protocol fee per order (your MRR wallet)
VITE_TREASURY_MAINNET=EQB_your_mainnet_treasury_address
VITE_TREASURY_TESTNET=EQB_your_testnet_treasury_address

# TON-Eats backend (Express + Socket.io)
VITE_BACKEND_URL=http://localhost:3001
